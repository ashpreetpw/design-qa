+++ b/src/components/TopNav.tsx
@@ -24,9 +24,9 @@ export default function TopNav() {
         data-component="SearchBar"
         className="flex flex-1 items-center gap-6 rounded-sm bg-white px-12 py-8 border border-strokeMed"
       >
